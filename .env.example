# Model A (DeepSeek):
# DEEPSEEK_API_KEY=your_deepseek_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model B and arbitration (Alibaba Cloud DashScope OpenAI-compatible API):
# DASHSCOPE_API_KEY=your_dashscope_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model B defaults to qwen3.7-plus through DashScope with thinking disabled.
# Arbitration defaults to glm-5 through DashScope with thinking enabled.

# Local OpenAI-compatible endpoints can be selected with command-line
# --model-a-provider/--model-b-provider and --model-a-base-url/--model-b-base-url.
